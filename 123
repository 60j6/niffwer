local player = Players.LocalPlayer
local TopRight = player:WaitForChild("PlayerGui"):WaitForChild("GUI"):WaitForChild("TopRight")
local KillIcons = ReplicatedStorage:WaitForChild("KillIcons")

local imageMap = {}

for _, melee in ipairs(meleeChoices) do
	local nameObj = KillIcons:FindFirstChild(melee.Name)
	local switchObj = KillIcons:FindFirstChild(melee.Switch)

	if nameObj and switchObj then
		local switchId = switchObj.Value:match("%d+")
		local nameId = nameObj.Value:match("%d+")

		if switchId and nameId then
			imageMap[switchId] = "rbxassetid://" .. nameId
		end
	end
end

local function hookFrame(frame)
	if not frame:IsA("Frame") then return end

	local killer = frame:WaitForChild("Killer", 2)
	local pic = frame:WaitForChild("Pic", 2)

	if not killer or not pic then return end

	local function update()
		if killer.Text ~= player.Name then return end

		local currentId = pic.Image:match("%d+")
		if not currentId then return end

		local replacement = imageMap[currentId]
		if replacement then
			pic.Image = replacement
		end
	end
	killer:GetPropertyChangedSignal("Text"):Connect(update)
	pic:GetPropertyChangedSignal("Image"):Connect(update)
	update()
end
for _, frame in ipairs(TopRight:GetChildren()) do
	hookFrame(frame)
end
TopRight.ChildAdded:Connect(function(frame)
	hookFrame(frame)
end)
