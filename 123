local function watchSlots()
    local meleeSlots = locker:FindFirstChild("Slots")
    if not meleeSlots then return end

    meleeSlots = meleeSlots:FindFirstChild("Melees")
    if not meleeSlots then return end

    local function hook(slot)
        local img = slot:FindFirstChild("ImageLabel")
        if not img then return end

        local function enforce()
            if oldImageId and img.Image == oldImageId then
                img.Image = ACT_IMAGE
            end
        end

        enforce()
        img:GetPropertyChangedSignal("Image"):Connect(enforce)
    end

    for _, v in ipairs(meleeSlots:GetChildren()) do
        hook(v)
    end

    meleeSlots.ChildAdded:Connect(function(child)
        task.wait()
        hook(child)
    end)
end

