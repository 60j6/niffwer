local function applyModel(model)
    for _, item in ipairs(model:GetDescendants()) do
        if (item:IsA("BasePart") or item:IsA("MeshPart")) and item.Name == "Model" then
            item:Destroy()
        end
    end

    local weapon = weaponsFolder:FindFirstChild(weaponName)
    if not weapon then return end

    local weaponModel = weapon:FindFirstChild("Model")
    if not (weaponModel and weaponModel:IsA("MeshPart")) then return end

    local clonedWeapon = weaponModel:Clone()
    clonedWeapon.Parent = model
    clonedWeapon.Anchored = false
    clonedWeapon.CanCollide = false

    local gunWeld = weaponModel:FindFirstChild("GunWeld")
    local rightHand = model:FindFirstChild("RightHand")

    if gunWeld and rightHand then
        local newGunWeld = Instance.new("Weld")
        newGunWeld.Name = "GunWeld"
        newGunWeld.Part0 = rightHand
        newGunWeld.Part1 = clonedWeapon
        newGunWeld.C0 = gunWeld.C0
        newGunWeld.C1 = gunWeld.C1
        newGunWeld.Parent = clonedWeapon
    end

    local humanoid = model:FindFirstChildWhichIsA("Humanoid")
    if humanoid then
        local animator = humanoid:FindFirstChildWhichIsA("Animator")
            or Instance.new("Animator", humanoid)

        local equipAnim = weapon:FindFirstChild("Equip", true)
        local idleAnim = weapon:FindFirstChild("Idle", true)

        if equipAnim and idleAnim then
            local equipTrack = animator:LoadAnimation(equipAnim)
            local idleTrack = animator:LoadAnimation(idleAnim)

            equipTrack:Play()
            equipTrack.Stopped:Once(function()
                idleTrack.Looped = true
                idleTrack:Play()
            end)
        end
    end
end

