local function attachAccessory(accessory, character)
	local handle = accessory:FindFirstChild("Handle")
	if not handle then return end

	local accAttachment
	for _, att in ipairs(handle:GetChildren()) do
		if att:IsA("Attachment") and attachmentMap[att.Name] then
			accAttachment = att
			break
		end
	end

	handle.Parent = character
	handle.Massless = true
	handle.Anchored = false
	handle.CanCollide = false
	
	CollectionService:AddTag(handle, "JoeAccessory")

	if accAttachment then
		local targetName = attachmentMap[accAttachment.Name]
		for _, att in ipairs(character:GetDescendants()) do
			if att:IsA("Attachment") and att.Name == targetName then
				local weld = Instance.new("Weld")
				weld.Name = "AccessoryWeld"
				weld.Part0 = handle
				weld.Part1 = att.Parent
				weld.C0 = handle.CFrame:ToObjectSpace(accAttachment.WorldCFrame)
				weld.C1 = att.Parent.CFrame:ToObjectSpace(att.WorldCFrame)
				weld.Parent = handle
				handle.CFrame = att.WorldCFrame * weld.C1:Inverse() * weld.C0
				return
			end
		end
	end

	local root = character:FindFirstChild("HumanoidRootPart")
	if root then
		local weld = Instance.new("Weld")
		weld.Name = "AccessoryWeld"
		weld.Part0 = handle
		weld.Part1 = root
		weld.Parent = handle
		handle.CFrame = root.CFrame
	end
end

local function applyAvatar(character)
	removeJoeAccessories(character)
	removeJoeClothing(character)

	if not isJoeSkin() then return end

	stripCharacter(character)

	for _, obj in ipairs(AvatarDummy:GetChildren()) do
		if obj:IsA("Accessory") or obj:IsA("Hat") then
			attachAccessory(obj:Clone(), character)
		else
			local clone = obj:Clone()
			clone.Parent = character

			if clone:IsA("Shirt") or clone:IsA("Pants") or clone:IsA("ShirtGraphic") then
				CollectionService:AddTag(clone, "JoeClothing")
			end
		end
	end

	applyJoeFakeHeadColor(character)
end
