local originalState = {}

local function cacheOriginal(model)
	if originalState[model] then return end

	local data = {}

	for _, v in ipairs(model:GetDescendants()) do
		if v:IsA("BasePart") then
			data[v] = {
				Transparency = v.Transparency,
				CanCollide = v.CanCollide,
				CanQuery = v.CanQuery,
				CanTouch = v.CanTouch,
			}

		elseif v:IsA("Decal") or v:IsA("Texture") then
			data[v] = {
				Transparency = v.Transparency
			}

		elseif v:IsA("ParticleEmitter") then
			data[v] = {
				Enabled = v.Enabled
			}

		elseif v:IsA("Beam") or v:IsA("Trail") then
			data[v] = {
				Enabled = v.Enabled
			}
		end
	end

	originalState[model] = data
end

local function applyOriginal(model)
	local data = originalState[model]
	if not data then return end

	for obj, props in pairs(data) do
		if obj and obj.Parent then
			for k, v in pairs(props) do
				obj[k] = v
			end
		end
	end
end

