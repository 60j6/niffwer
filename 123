local function setGunInvisible(gun)
	for _, v in ipairs(gun:GetDescendants()) do
		if v:IsA("BasePart") then
			v.Transparency = 1
		elseif v:IsA("Decal") or v:IsA("Texture") then
			v.Transparency = 1
		elseif v:IsA("ParticleEmitter") then
			v.Enabled = false
		elseif v:IsA("Beam") or v:IsA("Trail") then
			v.Transparency = NumberSequence.new(1)
		end
	end
end

local function applyPhysics(model)
	for _, v in ipairs(model:GetDescendants()) do
		if v:IsA("BasePart") or v:IsA("Meshpart") then
			v.Massless = true
			v.CanTouch = false
			v.CanQuery = false
			v.CanCollide = false
		end
	end
end

local function applyTeamColor(model)
	local teamColor = player.TeamColor.Color

	for _, v in ipairs(model:GetDescendants()) do
		if (v:IsA("BasePart") or v:IsA("MeshPart")) and string.find(string.lower(v.Name), "teamcolor") then
			v.BrickColor = BrickColor.new(teamColor)
		end
	end
end

local function attach(wrap)
	if cloneModel then return end

	local meleeFolder = meleesFolder:FindFirstChild(meleeValue.Value)
	if not meleeFolder then return end

	local model = meleeFolder:FindFirstChild("Model")
	if not model then return end

	cloneModel = model:Clone()
	cloneModel.Parent = player.Character

	cacheOriginal(cloneModel)

	applyPhysics(cloneModel)
	applyTeamColor(cloneModel)

	local rightHand = player.Character and player.Character:FindFirstChild("RightHand")
	if not rightHand then return end

	local weld = cloneModel:FindFirstChildOfClass("Weld")
	if weld then
		weld.Part1 = cloneModel
		weld.Part0 = rightHand
	end
end

